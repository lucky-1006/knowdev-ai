# CodePilot AI Backend Environment Configuration

# App environment mode (development / production)
ENV_MODE=development

# Database connection URL
# For local SQLite development (default):
DATABASE_URL=sqlite:///./codepilot.db
# For production PostgreSQL:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/codepilot

# GitHub Configuration
GITHUB_TOKEN=your_github_personal_access_token_here

# Vector Database Configuration (Qdrant)
# For local memory/filesystem testing:
QDRANT_HOST=memory
QDRANT_PORT=6333
# For Qdrant Cloud or Docker container:
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_API_KEY=your_qdrant_cloud_api_key_here

# AI Model settings
# Set to true to run PyTorch inference locally, false to use mock fallbacks
LOCAL_INFERENCE=false
DEFAULT_MODEL=qwen2.5
MODELS_DIR=./models/weights
